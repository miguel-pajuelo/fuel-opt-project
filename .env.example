# Copy this file to .env and fill only your local/private values.
# Never commit .env with real secrets.

ORS_API_KEY=

# Optional local overrides.
GAS_DB_PATH=data/db/gas_stations.sqlite
MINETUR_SNAPSHOT_PATH=data/cache/minetur_snapshot.json
BALLENOIL_RESULT_PATH=data/cache/ballenoil_espana_combustible.txt
BALLENOIL_PRICES_PATH=data/cache/ballenoil_precios.json
CONSUMPTION_L_100KM=5.5
MAX_ROUTE_CANDIDATES=75
PREFILTER_RADIUS_KM=40
LOCAL_SEARCH_RADIUS_KM=50
CORRIDOR_RADIUS_KM=10
MAX_SEARCH_EXTENT_KM=150
OPTIMIZATION_MODE=economic
ROUTE_DETOUR_FACTOR=1.25
SAME_PLACE_THRESHOLD_KM=1.0
MAX_BRANDS_PER_REQUEST=10

# Observabilidad y alertas
SENTRY_DSN=           # DSN de tu proyecto en sentry.io (dejar vacío para deshabilitar)
ALERT_WEBHOOK_URL=    # Webhook para alertas de refresco fallido (Telegram, Slack, ntfy.sh)

# CORS (solo necesario si frontend y API están en dominios distintos)
CORS_ORIGINS=         # Lista separada por comas. Ej: https://fuelopt.es,https://www.fuelopt.es
