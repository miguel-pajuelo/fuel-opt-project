# FuelOpt environment example
# Copy this file to .env for local development.
# Keep real secrets only in .env or in your deployment secret manager.

# Required for geocoding and real route geometry.
# Replace with your own key, or leave empty to use Haversine-only fallback flows.
ORS_API_KEY=replace-me
# Admin token for POST /catalog/refresh. Replace with a long random value.
FUELOPT_ADMIN_TOKEN=replace-me
FUELOPT_ENABLE_API_DOCS=false

# Optional local paths. Defaults work for the repository layout.
GAS_DB_PATH=data/db/gas_stations.sqlite
MINETUR_SNAPSHOT_PATH=data/cache/minetur_snapshot.json
BALLENOIL_RESULT_PATH=data/cache/ballenoil_espana_combustible.txt
BALLENOIL_PRICES_PATH=data/cache/ballenoil_precios.json

# Optimization defaults.
CONSUMPTION_L_100KM=5.5
MAX_ROUTE_CANDIDATES=75
PREFILTER_RADIUS_KM=40
LOCAL_SEARCH_RADIUS_KM=50
CORRIDOR_RADIUS_KM=10
MAX_SEARCH_EXTENT_KM=150
OPTIMIZATION_MODE=economic
ROUTE_DETOUR_FACTOR=1.25
SAME_PLACE_THRESHOLD_KM=1.0
MAX_BRANDS_PER_REQUEST=10

# Web/API deployment options.
# Empty means same-origin frontend/API only.
CORS_ORIGINS=
ALERT_WEBHOOK_URL=

# Feedback form SMTP settings. Leave empty to disable feedback sending.
GMAIL_USER=replace-me@example.com
GMAIL_APP_PASSWORD=replace-me
FEEDBACK_RECIPIENT=

# Local launcher options.
FUELOPT_PROJECT_ROOT=
FUELOPT_ALLOW_LAN=0

# Public-deployment hardening. Keep disabled (0) for local use; enable only
# behind a trusted reverse proxy. See docs/SECRETS_AND_ENV.md and
# docs/SECURITY_HARDENING_H3_H6_H8.md.
FUELOPT_TRUST_PROXY_HEADERS=0
FUELOPT_LOG_CLIENT_IP=0

# Legacy Ballenoil scraper tuning.
BALLENOIL_MAX_WORKERS=6
